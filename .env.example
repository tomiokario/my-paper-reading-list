# Copy to .env and fill in local/private values.
# Do not commit .env.

# Notion
NOTION_TOKEN=
NOTION_PAPER_DATABASE_ID=

# Optional GitHub token for private repositories or higher rate limits.
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_PROJECT_OWNER=
GITHUB_PROJECT_NUMBER=

# Local private data root.
# Example:
# PAPER_READING_DATA_ROOT=C:\path\to\private\paper-reading-data
PAPER_READING_DATA_ROOT=

# Optional translation provider settings.
TRANSLATION_PROVIDER=
DEEPL_API_KEY=
